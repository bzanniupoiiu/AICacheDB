红黑树是一个自平衡的二叉搜索树，其中每个节点包含一个颜色属性。下面是一个简化的红黑树的C语言实现，它包含了基本的节点结构、颜色枚举、树的基本操作，以及一些关键的红黑树操作。

请注意，以下代码是为了说明红黑树的工作原理而编写的，它不是经过优化的实现。在实际应用中，可能需要添加更多的错误检查和性能优化。

```c
#include <stdio.h>
#include <stdlib.h>

// 定义红黑树节点颜色
typedef enum {
    RED,
    BLACK
} NodeColor;

// 定义红黑树节点结构
typedef struct RBTreeNode {
    int data;
    NodeColor color;
    struct RBTreeNode *parent;
    struct RBTreeNode *left;
    struct RBTreeNode *right;
} RBTreeNode;

// 创建新的红黑树节点
RBTreeNode* createNode(int data, NodeColor color) {
    RBTreeNode* newNode = (RBTreeNode*)malloc(sizeof(RBTreeNode));
    newNode->data = data;
    newNode->color = color;
    newNode->parent = NULL;
    newNode->left = NULL;
    newNode->right = NULL;
    return newNode;
}

// 插入节点
void insertNode(RBTreeNode** root, int data) {
    RBTreeNode* parent = NULL;
    RBTreeNode* node = *root;

    // 搜索插入位置
    while (node != NULL) {
        parent = node;
        if (data < node->data)
            node = node->left;
        else if (data > node->data)
            node = node->right;
        else
            return; // 重复数据，不插入
    }

    // 创建新节点并插入
    RBTreeNode* newNode = createNode(data, RED);
    newNode->parent = parent;

    if (parent == NULL)
        *root = newNode; // 新节点成为根节点
    else if (data < parent->data)
        parent->left = newNode;
    else
        parent->right = newNode;

    // 新插入的节点为红色
    newNode->color = RED;
    // 调整树平衡（略）
}

// 转换函数（略）
// 左旋、右旋（略）

// 红黑树平衡操作（略）

// 打印树（略）

int main() {
    RBTreeNode* root = NULL;

    // 插入节点
    insertNode(&root, 10);
    insertNode(&root, 20);
    insertNode(&root, 30);
    // ... 添加更多节点

    // 打印树（可选）
    // printTree(root);

    // 清理树（略）

    return 0;
}
```

