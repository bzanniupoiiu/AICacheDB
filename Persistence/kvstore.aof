红黑树是一种自平衡的二叉查找树，它通过颜色和旋转操作来保证树的高度平衡，从而确保查找、插入和删除操作的时间复杂度都为O(log n)。下面是一个简化的C语言版本的红黑树实现，包括节点定义、树的基本操作以及插入操作。

```c
#include <stdio.h>
#include <stdlib.h>

// 定义红黑树的节点颜色
typedef enum { RED, BLACK } NodeColor;

// 定义红黑树的节点结构
typedef struct Node {
    int data;
    NodeColor color;
    struct Node *left, *right, *parent;
} Node;

// 定义红黑树结构
typedef struct RBTree {
    Node *root;
} RBTree;

// 创建一个新的节点
Node* createNode(int data, NodeColor color) {
    Node *newNode = (Node*)malloc(sizeof(Node));
    if (!newNode) return NULL;
    newNode->data = data;
    newNode->color = color;
    newNode->left = newNode->right = newNode->parent = NULL;
    return newNode;
}

// 右旋
void rotateRight(Node **root, Node *x) {
    Node *y = x->left;
    x->left = y->right;
    if (y->right) y->right->parent = x;
    y->parent = x->parent;
    if (!x->parent) *root = y;
    else if (x == x->parent->right) x->parent->right = y;
    else x->parent->left = y;
    y->right = x;
    x->parent = y;
}

// 左旋
void rotateLeft(Node **root, Node *x) {
    Node *y = x->right;
    x->right = y->left;
    if (y->left) y->left->parent = x;
    y->parent = x->parent;
    if (!x->parent) *root = y;
    else if (x == x->parent->left) x->parent->left = y;
    else x->parent->right = y;
    y->left = x;
    x->parent = y;
}

// 插入节点并调整树
void insertNode(RBTree *tree, Node **root, Node *node) {
    Node *y = NULL;
    Node *x = *root;
    while (x) {
        y = x;
        if (node->data < x->data) x = x->left;
        else x = x->right;
    }
    node->parent = y;
    if (!y) *root = node;
    else if (node->data < y->data) y->left = node;
    else y->right = node;

    node->color = RED;
    fixInsertion(tree, root, node);
}

// 插入后修复树
void fixInsertion(RBTree *tree, Node **root, Node *node) {
    while (node != *root && node->parent->color == RED) {
        if (node->parent == node->parent->parent->left) {
            Node *uncle = node->parent->parent->right;
            if (uncle && uncle->color == RED) {
                node->parent->color = BLACK;
                uncle->color = BLACK;
                node->parent->parent->color = RED;
                node = node->parent->parent;
            } else {
                if (node == node->parent->right) {
                    node = node->parent;
                    rotateLeft(root, node);
                }
                node->parent->color = BLACK;
                node->parent->parent->color = RED;
                rotateRight(root, node->parent->parent);
            }
        } else {
            Node *uncle = node->parent->parent->left;
            if (uncle && uncle->color == RED) {
                node->parent->color = BLACK;
                uncle->color = BLACK;
                node->parent->parent->color = RED;
                node = node->parent->parent;
            } else {
                if (node == node->parent->left) {
                    node = node->parent;
                    rotateRight(root, node);
                }
                node->parent->color = BLACK;
                node->parent->parent->color = RED;
                rotateLeft(root, node->parent->parent);
            }
        }
    }
    (*root)->color = BLACK;
}

// 主函数，用于测试红黑树
int main() {
    RBTree tree = {NULL};
    Node *root = NULL;

    // 插入节点
    root = createNode(10, RED);
    insertNode(&tree, &root, root);
    insertNode(&tree, &root, createNode(20, RED));
    insertNode(&tree, &root, createNode(30, RED));
    insertNode(&tree, &root, createNode(40, RED));
    insertNode(&tree, &root, createNode(50, RED));
    insertNode(&tree, &root, createNode(25, RED));

    // 打印树，这里只是一个简单的打印函数，实际应用中可能需要更复杂的打印函数
    void printTree(Node *node, int space) {
        int i;
        if (node == NULL) return;
        space += 10;
        printTree(node->right, space);
        printf("\n");
        for (i = 10; i < space; i++)
            printf(" ");
        printf("%d\n", node->data);
        printTree(node->left, space);
    }

    printTree(root, 0);

    // 释放树内存
    // ... 释放树内存的代码 ...

    return 0;
}
```

请注意，上述代码仅展示了红黑树的基本插入操作，并没有包含删除操作和完整的错误处理。在实际应用中，您可能还需要添加更多的功能，例如查找、删除、遍历和内存释放等。此外，为了简化，上述代码中的打印函数非常基础，它仅用于展示树的结构。在真实场景中，您可能需要一个更复杂的打印函数来展示树的颜色信息。
